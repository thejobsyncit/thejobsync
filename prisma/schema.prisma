// Prisma Schema — ManpowerCRM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== USER ====================
model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  role       String   // super_admin | it_admin | admin | recruiter | interviewer | hr | client | placement_coordinator | developer | tester
  phone      String   @default("")
  avatar     String?
  department String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  interviews            Interview[] @relation("InterviewInterviewer")
  notifications         Notification[]
  auditLogs             AuditLog[]
  attendances           Attendance[]
  loginLogs             LoginLog[]
  assignedCandidatesHr  Candidate[] @relation("AssignedHR")
  assignedCandidatesInt Candidate[] @relation("AssignedInterviewer")
  followUps             FollowUp[]
  leaveRequests         LeaveRequest[]
  createdTickets        Ticket[]          @relation("TicketCreator")
  sentMessages          TicketMessage[]   @relation("MessageSender")
  
  // Leads workflow
  dmsLeads              CompanyLead[]     @relation("DMSLeads")
  coordinatorLeads      CompanyLead[]     @relation("CoordinatorLeads")
}

// ==================== CLIENT ====================
model Client {
  id            String   @id @default(cuid())
  companyName   String
  contactPerson String
  email         String
  phone         String
  address       String
  industry      String
  website       String?
  status        String   @default("active") // active | inactive
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  requirements JobRequirement[]
  placements   Placement[]
}

// ==================== JOB REQUIREMENT ====================
model JobRequirement {
  id                 String   @id @default(cuid())
  clientId           String
  title              String
  description        String
  skills             String   // JSON array stored as string
  experience         String
  positions          Int
  filledPositions    Int      @default(0)
  location           String
  salaryRange        String
  status             String   @default("open") // open | in_progress | on_hold | closed | cancelled
  priority           String   @default("medium") // low | medium | high | urgent
  assignedRecruiters String   @default("[]") // JSON array stored as string
  deadline           String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  client     Client       @relation(fields: [clientId], references: [id])
  candidates Candidate[]
  interviews Interview[]
  placements Placement[]
  candidateApplications CandidateApplication[]
  savedByCandidates CandidateSavedJob[]
}

// ==================== CANDIDATE ====================
model Candidate {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String
  skills          String   // JSON array stored as string
  experience      String
  education       String
  currentCompany  String?
  currentRole     String?
  expectedSalary  String?
  languages       String?
  location        String
  resumeUrl       String?
  status          String   @default("new") // new | shortlisted | interview_scheduled | interviewed | selected | rejected | offered | joined | withdrawn
  appliedFor            String?  // requirementId
  assignedHrId          String?
  assignedInterviewerId String?
  notes                 String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  requirement JobRequirement? @relation(fields: [appliedFor], references: [id])
  assignedHr  User?           @relation("AssignedHR", fields: [assignedHrId], references: [id])
  assignedInt User?           @relation("AssignedInterviewer", fields: [assignedInterviewerId], references: [id])
  interviews  Interview[]
  placements  Placement[]
  documents   Document[]
  followUps   FollowUp[]
}

// ==================== INTERVIEW ====================
model Interview {
  id               String   @id @default(cuid())
  candidateId      String
  requirementId    String
  interviewerId    String
  scheduledAt      String
  duration         Int      @default(60) // minutes
  type             String   @default("technical") // phone | video | in_person | technical | hr
  status           String   @default("scheduled") // scheduled | in_progress | completed | cancelled | no_show
  feedback         String?
  rating           Int?     // 1-5
  recommendation   String?  // select | reject | hold
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  candidate   Candidate      @relation(fields: [candidateId], references: [id])
  requirement JobRequirement @relation(fields: [requirementId], references: [id])
  interviewer User           @relation("InterviewInterviewer", fields: [interviewerId], references: [id])
}

// ==================== PLACEMENT ====================
model Placement {
  id              String   @id @default(cuid())
  candidateId     String
  requirementId   String
  clientId        String
  position        String
  salary          String
  joiningDate     String
  status          String   @default("offer_sent") // offer_sent | offer_accepted | joining_confirmed | joined | cancelled
  offerLetterUrl  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  candidate   Candidate      @relation(fields: [candidateId], references: [id])
  requirement JobRequirement @relation(fields: [requirementId], references: [id])
  client      Client         @relation(fields: [clientId], references: [id])
}

// ==================== NOTIFICATION ====================
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info | success | warning | error
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
}

// ==================== AUDIT LOG ====================
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String
  module    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
}

// ==================== FOLLOW UPS ====================
model FollowUp {
  id          String   @id @default(cuid())
  candidateId String
  hrId        String
  status      String
  remarks     String?
  createdAt   DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  hr        User      @relation(fields: [hrId], references: [id], onDelete: Cascade)
}

// ==================== DOCUMENTS (DMS) ====================
model Document {
  id          String   @id @default(cuid())
  candidateId String
  type        String   // resume | aadhaar | pan | edu_cert | offer_letter | appointment_letter | other
  name        String
  url         String
  uploadedAt  DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

// ==================== ATTENDANCE & LOGS ====================
model Attendance {
  id          String    @id @default(cuid())
  userId      String
  date        String    // Format: YYYY-MM-DD
  loginTime   DateTime
  logoutTime  DateTime?
  status      String    // present | absent | late
  totalHours  Float?
  isApproved  Boolean   @default(true) // For late logins > 09:15 AM
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions AttendanceSession[]

  @@unique([userId, date])
}

model AttendanceSession {
  id           String     @id @default(cuid())
  attendanceId String
  loginTime    DateTime   @default(now())
  logoutTime   DateTime?
  
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String
  timestamp DateTime @default(now())
  ipAddress String?
  userAgent String?
  status    String   // success | blocked | pending_approval
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== INTERNAL HELPDESK & LEAVE ====================
model LeaveRequest {
  id        String   @id @default(cuid())
  userId    String
  startDate String   // Format: YYYY-MM-DD
  endDate   String   // Format: YYYY-MM-DD
  reason    String
  status    String   @default("pending") // pending | approved | rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ticket {
  id           String   @id @default(cuid())
  creatorId    String
  assignedRole String   // super_admin | admin | it_admin
  subject      String
  status       String   @default("open") // open | resolved | closed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator  User            @relation("TicketCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  messages TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  senderId  String
  message   String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
}

// ==================== CANDIDATE PORTAL ====================
model CandidateAccount {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  phone          String
  password       String
  headline       String?
  summary        String?
  skills         String    @default("[]") // JSON array
  experience     String?
  education      String?
  languages      String?
  location       String?
  resumeUrl      String?
  photoUrl       String?
  currentCompany String?
  currentRole    String?
  expectedSalary String?
  preferredRoles String?
  isVerified     Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  applications CandidateApplication[]
  savedJobs    CandidateSavedJob[]
  messages     CandidateMessage[]
  savedByEmployers EmployerSavedCandidate[]
  subscriptions  CandidateSubscription[]
  invoices       CandidateInvoice[]
}

model CandidateApplication {
  id                 String           @id @default(cuid())
  candidateAccountId String
  requirementId      String?
  coverNote          String?
  status             String           @default("applied") // applied | shortlisted | interviewing | selected | rejected
  appliedAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)
  requirement      JobRequirement?  @relation(fields: [requirementId], references: [id])
}

model CandidateSavedJob {
  id                 String           @id @default(cuid())
  candidateAccountId String
  requirementId      String
  savedAt            DateTime         @default(now())

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)
  requirement      JobRequirement   @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([candidateAccountId, requirementId])
}

model CandidateMessage {
  id                 String           @id @default(cuid())
  candidateAccountId String
  sender             String           // "hr" or "candidate"
  message            String
  isRead             Boolean          @default(false)
  sentAt             DateTime         @default(now())

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)
}

model CandidateSubscription {
  id                  String    @id @default(cuid())
  candidateAccountId  String
  planName            String    // "JS Basic Resume", "JS Pro Resume", "JS Company Reference", "JS Company Assistance"
  amount              Float
  gstAmount           Float     @default(0)
  totalAmount         Float
  currency            String    @default("INR")
  razorpayOrderId     String?
  razorpayPaymentId   String?
  razorpaySignature   String?
  status              String    @default("pending") // pending | active | expired
  expiresAt           DateTime
  createdAt           DateTime  @default(now())

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)
}

model CandidateInvoice {
  id                 String   @id @default(cuid())
  invoiceNumber      String   @unique
  candidateAccountId String
  candidateName      String
  email              String
  planName           String
  amount             Float
  gstAmount          Float    @default(0)
  totalAmount        Float
  status             String   @default("pending") // pending | paid | cancelled
  paidAt             DateTime?
  createdAt          DateTime @default(now())

  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)
}

// ==================== ERP MODELS ====================

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  coverImage  String?
  author      String
  status      String   @default("draft") // draft | published
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  isActive    Boolean  @default(true)
  subscribedAt DateTime @default(now())
}

model Package {
  id           String   @id @default(cuid())
  name         String
  price        Float
  duration     Int      @default(30) // days
  jobPosts     Int      @default(5)
  resumeViews  Int      @default(50)
  features     String   @default("[]") // JSON array
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Coupon {
  id           String   @id @default(cuid())
  code         String   @unique
  discount     Float    // percentage
  maxUses      Int      @default(100)
  usedCount    Int      @default(0)
  validFrom    String
  validUntil   String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model MediaFile {
  id         String   @id @default(cuid())
  name       String
  url        String
  type       String   // image | video | document
  size       Int      @default(0) // bytes
  uploadedBy String?
  createdAt  DateTime @default(now())
}

model Location {
  id        String   @id @default(cuid())
  name      String
  state     String?
  country   String   @default("India")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PaymentSetting {
  id              String   @id @default(cuid())
  gatewayName     String   @default("razorpay") // razorpay | stripe
  apiKey          String   @default("")
  apiSecret       String   @default("")
  gstRate         Float    @default(18.0)
  invoicePrefix   String   @default("INV")
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  companyName   String
  email         String
  packageName   String
  amount        Float
  gstAmount     Float    @default(0)
  totalAmount   Float
  status        String   @default("pending") // pending | paid | cancelled
  paidAt        DateTime?
  createdAt     DateTime @default(now())
}

// ==================== EMPLOYER PORTAL ====================

model Employer {
  id            String   @id @default(cuid())
  companyName   String
  gstNumber     String
  address       String
  contactPerson String
  contactPhone  String
  email         String   @unique
  password      String
  industry      String
  about         String
  logoUrl       String?
  website       String?
  isVerified    Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  jobs EmployerJob[]
  savedCandidates EmployerSavedCandidate[]
  subscriptions EmployerSubscription[]
}

model EmployerJob {
  id          String   @id @default(cuid())
  employerId  String
  title       String
  description String
  skills      String   @default("[]")
  experience  String
  location    String
  salaryRange String
  jobType     String   @default("full-time")
  field       String
  openings    Int      @default(1)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employer Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
}

model EmployerSavedCandidate {
  id                 String           @id @default(cuid())
  employerId         String
  candidateAccountId String
  savedAt            DateTime         @default(now())

  employer         Employer         @relation(fields: [employerId], references: [id], onDelete: Cascade)
  candidateAccount CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)

  @@unique([employerId, candidateAccountId])
}

model EmployerSubscription {
  id                  String    @id @default(cuid())
  employerId          String
  planName            String    // e.g. "Hot Vacancy", "3-Job Pack"
  planType            String    @default("job_posting") // job_posting | resdex
  jobsAllowed         Int       @default(0)
  jobsUsed            Int       @default(0)
  resumeViewsAllowed  Int       @default(0)
  resumeViewsUsed     Int       @default(0)
  amount              Float
  gstAmount           Float     @default(0)
  totalAmount         Float
  currency            String    @default("INR")
  razorpayOrderId     String?
  razorpayPaymentId   String?
  razorpaySignature   String?
  status              String    @default("active") // active | expired | pending
  expiresAt           DateTime
  createdAt           DateTime  @default(now())

  employer Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
}

// ==================== COMPANY LEADS (DMS & Coordinator) ====================
model CompanyLead {
  id                 String   @id @default(cuid())
  companyName        String
  email              String?
  phone              String?
  status             String   @default("fresh") // fresh | rnr | switch_off | call_back | interested | not_interested | updated
  contactPerson      String?
  position           String?
  website            String?
  address            String?
  requirementDetails String?
  validityTime       String?
  remark             String?
  dmsId              String
  coordinatorId      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  dms         User  @relation("DMSLeads", fields: [dmsId], references: [id])
  coordinator User? @relation("CoordinatorLeads", fields: [coordinatorId], references: [id])
}

// ==================== PASSWORD RESET ====================
model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  role      String   // user | candidate | employer
  expiresAt DateTime
  createdAt DateTime @default(now())
}
